@{
    ViewBag.Title = "Dashboard Principal";
}

<div class="container mt-4">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border-start border-primary border-5">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold">Sistema de Gestión de Tareas</h1>
            <p class="col-md-8 fs-4 text-muted">Bienvenido al panel de control del Grupo 6. Aquí puedes administrar proyectos, asignar responsabilidades y monitorear el avance de cada tarea en tiempo real.</p>
            <hr class="my-4">
            <div class="d-flex gap-2">
                @Html.ActionLink("Ver Mis Tareas", "Index", "Tareas", null, new { @class = "btn btn-primary btn-lg px-4" })
                @Html.ActionLink("Nuevo Proyecto", "Create", "Proyecto", null, new { @class = "btn btn-outline-secondary btn-lg px-4" })
            </div>
        </div>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-people-fill text-primary" style="font-size: 2rem;"></i>
                    </div>
                    <h3 class="h5">Usuarios</h3>
                    <p class="text-muted small">Administra los integrantes del equipo y sus roles asignados.</p>
                    @Html.ActionLink("Gestionar", "Index", "Usuarios", null, new { @class = "btn btn-sm btn-outline-primary" })
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-folder-fill text-success" style="font-size: 2rem;"></i>
                    </div>
                    <h3 class="h5">Proyectos</h3>
                    <p class="text-muted small">Visualiza el estado de los proyectos actuales del ciclo.</p>
                    @Html.ActionLink("Ver Lista", "Index", "Proyecto", null, new { @class = "btn btn-sm btn-outline-success" })
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-check-circle-fill text-info" style="font-size: 2rem;"></i>
                    </div>
                    <h3 class="h5">Avance Real</h3>
                    <p class="text-muted small">Revisa cuáles tareas están pendientes o próximas a vencer.</p>
                    @Html.ActionLink("Revisar Tareas", "Index", "Tareas", null, new { @class = "btn btn-sm btn-outline-info" })
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}